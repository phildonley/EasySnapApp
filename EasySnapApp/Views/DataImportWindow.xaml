<Window x:Class="EasySnapApp.Views.DataImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Parts Data - Dynamic File Naming"
        Height="800"
        Width="1200"
        Background="#1E1E22"
        Foreground="#F0F0F0"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBrush" Color="#FF888888"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF4CAF50"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFF44336"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFFF9800"/>

        <!-- Modern Windows 11 Style ScrollViewer -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                     Grid.Column="1" Grid.Row="0"
                                     Orientation="Vertical"
                                     ViewportSize="{TemplateBinding ViewportHeight}"
                                     Maximum="{TemplateBinding ScrollableHeight}"
                                     Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                     Value="{TemplateBinding VerticalOffset}"
                                     Width="8"
                                     Background="#2A2A2E"
                                     BorderThickness="0"
                                     Margin="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#3A3A3E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                        Background="#3A3A3E" 
                                        BorderBrush="#555"
                                        BorderThickness="1"
                                        Focusable="False" 
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                        ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" 
                                            IsHitTestVisible="False" 
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            Margin="6,3,23,3"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup Name="Popup" 
                                 Placement="Bottom"
                                 IsOpen="{TemplateBinding IsDropDownOpen}"
                                 AllowsTransparency="True" 
                                 Focusable="False"
                                 PopupAnimation="Slide">
                                <Border Name="DropDownBorder"
                                      Background="#2A2A2E"
                                      BorderThickness="1"
                                      BorderBrush="#555"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="200">
                                    <ScrollViewer Margin="1" CanContentScroll="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#23272D"/>
            <Setter Property="Foreground" Value="#FAFAFA"/>
            <Setter Property="RowBackground" Value="#23272D"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="ColumnHeaderHeight" Value="30"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0F0F0"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#252526" Foreground="#F0F0F0">
            <TextBlock x:Name="StatusTextBlock"
                       Margin="8,0,0,0"
                       Foreground="#FF66FF66"
                       FontWeight="Bold"
                       FontSize="14"
                       Text="Select a CSV or Excel file to begin import"/>
        </StatusBar>

        <!-- Main Content -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Step 1: File Selection -->
            <GroupBox Grid.Row="0" Header="Step 1: File Selection" Margin="0,0,0,12" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="File:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                    <TextBox x:Name="FilePathTextBox" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="Browse..." Width="80" Margin="0,0,8,0" Click="BrowseButton_Click"/>
                    <Button x:Name="AnalyzeButton" Grid.Column="3" Content="Analyze" Width="80" IsEnabled="False" Click="AnalyzeButton_Click"/>
                </Grid>
            </GroupBox>

            <!-- Step 2: Header Detection and Preview -->
            <GroupBox Grid.Row="1" Header="Step 2: Header Detection &amp; Preview" Margin="0,0,0,12" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header Row Selection -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Header Row:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Bold"/>
                        <ComboBox x:Name="HeaderRowComboBox" Grid.Column="1" Width="80" Margin="0,0,8,0" 
                                  SelectionChanged="HeaderRowComboBox_SelectionChanged">
                            <ComboBoxItem Content="1"/>
                            <ComboBoxItem Content="2" IsSelected="True"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="None"/>
                            <ComboBoxItem Content="Custom..."/>
                        </ComboBox>

                        <TextBlock Grid.Column="2" Text="Total Rows:" VerticalAlignment="Center" Margin="16,0,8,0" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalRowsTextBlock" Grid.Column="3" Text="0" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <TextBlock x:Name="FileInfoTextBlock" Grid.Column="4" Text="" VerticalAlignment="Center" 
                                   Foreground="#CCCCCC" FontSize="11"/>

                        <Button x:Name="RefreshPreviewButton" Grid.Column="5" Content="Refresh Preview" Width="120" 
                                IsEnabled="False" Click="RefreshPreviewButton_Click"/>
                    </Grid>

                    <!-- Preview Status -->
                    <TextBlock x:Name="PreviewStatusTextBlock" Grid.Row="1" Text="" Foreground="#FFAA66" 
                               FontStyle="Italic" Visibility="Collapsed"/>
                </Grid>
            </GroupBox>

            <!-- Step 3: Data Preview and Column Selection -->
            <GroupBox Grid.Row="2" Header="Step 3: Column Selection &amp; Data Preview" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column Selection Panel -->
                    <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" Background="#2A2A2E" 
                            Margin="0,0,8,0" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Required Columns" FontWeight="Bold" Margin="0,0,0,8"/>

                            <!-- Part Number Column -->
                            <Grid Grid.Row="1" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Connection Key:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="ConnectionKeyColumnComboBox" Grid.Column="1" 
                                          SelectionChanged="ColumnMapping_SelectionChanged"/>
                            </Grid>

                            <!-- TMS ID Column -->
                            <Grid Grid.Row="2" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TMS ID:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="TmsIdColumnComboBox" Grid.Column="1" 
                                          SelectionChanged="ColumnMapping_SelectionChanged"/>
                            </Grid>

                            <!-- Display Name Column -->
                            <Grid Grid.Row="3" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Display Name:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="DisplayNameColumnComboBox" Grid.Column="1" 
                                          SelectionChanged="ColumnMapping_SelectionChanged"/>
                            </Grid>

                            <Separator Grid.Row="4" Margin="0,8,0,8"/>

                            <!-- Additional Columns -->
                            <ScrollViewer Grid.Row="5" Style="{StaticResource ModernScrollViewer}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Additional Columns (Optional)" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBox x:Name="ColumnSearchTextBox" 
                                             Margin="0,0,0,8"
                                             Background="#1E1E22"
                                             Foreground="#CCCCCC"
                                             BorderBrush="#555"
                                             Text="Search columns..."
                                             GotFocus="ColumnSearchTextBox_GotFocus"
                                             LostFocus="ColumnSearchTextBox_LostFocus"
                                             TextChanged="ColumnSearchTextBox_TextChanged"/>
                                    <ItemsControl x:Name="AdditionalColumnsPanel">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}" 
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          Tag="{Binding Index}"
                                                          Margin="0,2,0,2"
                                                          Checked="AdditionalColumn_CheckChanged"
                                                          Unchecked="AdditionalColumn_CheckChanged"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Selection Summary -->
                            <TextBlock x:Name="SelectionSummaryTextBlock" Grid.Row="6" 
                                       Text="Select required columns to continue"
                                       Foreground="#CCCCCC" FontSize="11" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>

                    <!-- Data Preview Panel -->
                    <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" Background="#23272D" Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Data Preview (First 10 Rows)" FontWeight="Bold" 
                                       Margin="8,4,8,8" Foreground="#CCCCCC"/>

                            <DataGrid x:Name="PreviewDataGrid" Grid.Row="1" 
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="True"
                                      CanUserSortColumns="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- Step 4: Import Execution -->
            <GroupBox Grid.Row="3" Header="Step 4: Import Execution" Padding="12" Margin="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Import Controls -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Progress Indicator -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                            <ProgressBar x:Name="ImportProgressBar" Width="200" Height="20" 
                                         Minimum="0" Maximum="100" Value="0"
                                         Visibility="Collapsed"/>
                            <TextBlock x:Name="ProgressTextBlock" Text="" VerticalAlignment="Center" 
                                       Margin="8,0,0,0" FontSize="11" Foreground="#CCCCCC"
                                       Visibility="Collapsed"/>
                        </StackPanel>

                        <!-- Import Summary -->
                        <TextBlock x:Name="ImportSummaryTextBlock" Grid.Column="1" Text="" 
                                   VerticalAlignment="Center" Foreground="#CCCCCC" FontSize="11"/>

                        <!-- Action Buttons -->
                        <Button x:Name="ValidateButton" Grid.Column="2" Content="Validate Mapping" 
                                Width="120" Margin="0,0,8,0" IsEnabled="False" Click="ValidateButton_Click"/>
                        <Button x:Name="ImportButton" Grid.Column="3" Content="Import Data" 
                                Width="100" Margin="0,0,8,0" IsEnabled="False" Click="ImportButton_Click"/>
                        <Button x:Name="CloseButton" Grid.Column="4" Content="Close" 
                                Width="80" Click="CloseButton_Click"/>
                    </Grid>

                    <!-- Import Log -->
                    <ScrollViewer Grid.Row="1" Height="120" Style="{StaticResource ModernScrollViewer}"
                                  Visibility="Collapsed" x:Name="ImportLogScrollViewer">
                        <TextBox x:Name="ImportLogTextBox"
                                 FontSize="11"
                                 Foreground="#CCCCCC"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 TextWrapping="NoWrap"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </ScrollViewer>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>