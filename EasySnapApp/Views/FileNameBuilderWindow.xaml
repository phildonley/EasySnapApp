<Window x:Class="EasySnapApp.Views.FileNameBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filename Pattern Builder"
        Height="660"
        Width="760"
        Background="#1E1E22"
        Foreground="#F0F0F0"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="TokenChipStyle" TargetType="Button">
            <Setter Property="Background"      Value="#3A3A4E"/>
            <Setter Property="Foreground"      Value="#E0E0FF"/>
            <Setter Property="BorderBrush"     Value="#5A5A7E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Margin"          Value="4,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5050A0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PatternItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="#2A2A3E"/>
            <Setter Property="Foreground"      Value="#E0E0FF"/>
            <Setter Property="BorderBrush"     Value="#444466"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4040A0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353555"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#888899"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,10,0,4"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#333344"/>
            <Setter Property="Foreground"      Value="#E0E0F0"/>
            <Setter Property="BorderBrush"     Value="#555566"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Margin"          Value="2,2"/>
            <Setter Property="MinWidth"        Value="60"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A6A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#555566"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background"      Value="#2A2A30"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="BorderBrush"     Value="#444455"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E1E22"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Filename Pattern Builder"
                       FontSize="18" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Configure how captured images are named, or repair existing files when database records are added later."
                       Foreground="#AAAAAA" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Tabs -->
        <TabControl Grid.Row="1"
                    Background="#1E1E22"
                    BorderBrush="#444455"
                    BorderThickness="1">

            <!-- TAB 1: Pattern Builder -->
            <TabItem Header="Pattern Builder">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Token Picker -->
                        <Border Grid.Column="0"
                                Background="#252530"
                                BorderBrush="#444455"
                                BorderThickness="1"
                                Padding="12">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="DATABASE FIELDS"
                                               Style="{StaticResource SectionHeaderStyle}"/>

                                    <Button Content="[TMS ID]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="TmsId"
                                            Click="AddFieldToken_Click"
                                            ToolTip="TMS record ID from parts database (e.g. 10025142). Omitted automatically if missing."/>

                                    <Button Content="[Display Name]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="DisplayName"
                                            Click="AddFieldToken_Click"
                                            ToolTip="Sanitized display name: lowercase, spaces to underscore (e.g. spring). Omitted automatically if missing."/>

                                    <Button Content="[Display Name (Raw)]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="DisplayNameRaw"
                                            Click="AddFieldToken_Click"
                                            ToolTip="Display name exactly as stored (e.g. SPRING). Omitted automatically if missing."/>

                                    <TextBlock Text="CAPTURE FIELDS"
                                               Style="{StaticResource SectionHeaderStyle}"/>

                                    <Button Content="[Part Number]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="PartNumber"
                                            Click="AddFieldToken_Click"
                                            ToolTip="The scanned Connection Key (e.g. 0090-193). Always present."/>

                                    <Button Content="[Sequence 000]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="Sequence000"
                                            Click="AddSequenceToken_Click"
                                            ToolTip="Zero-padded 3-digit sequence (e.g. 103). Always present."/>

                                    <Button Content="[Sequence #]"
                                            Style="{StaticResource TokenChipStyle}"
                                            Tag="Sequence0"
                                            Click="AddSequenceToken_Click"
                                            ToolTip="Unpadded sequence number (e.g. 103). Always present."/>

                                    <TextBlock Text="SEPARATORS"
                                               Style="{StaticResource SectionHeaderStyle}"/>

                                    <TextBlock Text="Separators adjacent to a missing field are removed automatically."
                                               Foreground="#666677"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>

                                    <WrapPanel>
                                        <Button Content="  .  " Style="{StaticResource TokenChipStyle}"
                                                Tag="." Click="AddSeparatorToken_Click"/>
                                        <Button Content="  _  " Style="{StaticResource TokenChipStyle}"
                                                Tag="_" Click="AddSeparatorToken_Click"/>
                                        <Button Content="  -  " Style="{StaticResource TokenChipStyle}"
                                                Tag="-" Click="AddSeparatorToken_Click"/>
                                        <Button Content=" space " Style="{StaticResource TokenChipStyle}"
                                                Tag=" " Click="AddSeparatorToken_Click"/>
                                    </WrapPanel>

                                    <TextBlock Text="STATIC TEXT"
                                               Style="{StaticResource SectionHeaderStyle}"/>

                                    <TextBlock Text="Add any fixed text: labels, years, codes, etc."
                                               Foreground="#666677"
                                               FontSize="10"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>

                                    <Border Background="#1A1A26"
                                            BorderBrush="#444455"
                                            BorderThickness="1"
                                            Padding="8"
                                            Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="e.g.  Image   pic   2025   ACME_"
                                                       Foreground="#555566"
                                                       FontSize="10"
                                                       FontStyle="Italic"
                                                       Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="StaticTextBox"
                                                         Grid.Column="0"
                                                         Background="#1E1E2A"
                                                         Foreground="#F0F0F0"
                                                         BorderBrush="#555566"
                                                         Padding="6,4"
                                                         Margin="0,0,4,0"
                                                         KeyDown="StaticTextBox_KeyDown"/>
                                                <Button Grid.Column="1"
                                                        Content="Add"
                                                        Style="{StaticResource ActionButtonStyle}"
                                                        MinWidth="40"
                                                        Click="AddStaticToken_Click"/>
                                            </Grid>
                                            <TextBlock Text="Press Enter or click Add"
                                                       Foreground="#555566"
                                                       FontSize="10"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Right: Pattern Editor -->
                        <Border Grid.Column="2"
                                Background="#252530"
                                BorderBrush="#444455"
                                BorderThickness="1"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="CURRENT PATTERN  (select an item to move or remove)"
                                           Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0,0,0,6"/>

                                <ListBox x:Name="PatternListBox"
                                         Grid.Row="1"
                                         Background="#1E1E2A"
                                         BorderBrush="#444455"
                                         BorderThickness="1"
                                         SelectionMode="Single"
                                         ItemContainerStyle="{StaticResource PatternItemStyle}"
                                         SelectionChanged="PatternListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       FontFamily="Consolas"
                                                       FontSize="13"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            Margin="0,8,0,8">
                                    <Button x:Name="MoveUpButton"
                                            Content="Up"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="MoveUp_Click"
                                            IsEnabled="False"/>
                                    <Button x:Name="MoveDownButton"
                                            Content="Down"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="MoveDown_Click"
                                            IsEnabled="False"/>
                                    <Button x:Name="RemoveTokenButton"
                                            Content="Remove"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="RemoveToken_Click"
                                            IsEnabled="False"/>
                                    <Button Content="Clear All"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="ClearAll_Click"/>
                                    <Button Content="Reset Default"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Foreground="#FFAA66"
                                            Click="ResetDefault_Click"/>
                                </StackPanel>

                                <!-- Live Preview -->
                                <Border Grid.Row="3"
                                        Background="#1A1A26"
                                        BorderBrush="#333344"
                                        BorderThickness="1"
                                        Padding="10,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="LIVE PREVIEW"
                                                       Style="{StaticResource SectionHeaderStyle}"
                                                       Margin="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="Sample part:"
                                                       Foreground="#888899"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <ComboBox x:Name="PreviewPartComboBox"
                                                      Grid.Column="3"
                                                      Width="200"
                                                      Background="#1E1E2A"
                                                      Foreground="#F0F0F0"
                                                      BorderBrush="#555566"
                                                      SelectionChanged="PreviewPart_Changed"/>
                                        </Grid>
                                        <TextBlock x:Name="PreviewTextBlock"
                                                   FontFamily="Consolas"
                                                   FontSize="14"
                                                   Foreground="#66FF99"
                                                   TextWrapping="Wrap"
                                                   Text="(add tokens to see preview)"/>
                                        <TextBlock x:Name="PreviewMissingTextBlock"
                                                   FontSize="10"
                                                   Foreground="#FFAA66"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 2: Repair Filenames -->
            <TabItem Header="Repair Filenames">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Description -->
                    <Border Grid.Row="0"
                            Background="#252530"
                            BorderBrush="#444455"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="BATCH FILENAME REPAIR"
                                       Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#CCCCCC" FontSize="12">
                                Use this utility when images were captured before database records existed.
                                Select a folder of images and this tool will look up each part number,
                                then rename any files that can now be enriched with database data.
                                Files already using the full pattern are skipped automatically.
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Folder picker -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RepairFolderTextBox"
                                 Grid.Column="0"
                                 Background="#1E1E2A"
                                 Foreground="#F0F0F0"
                                 BorderBrush="#555566"
                                 Padding="6,4"
                                 Margin="0,0,6,0"
                                 IsReadOnly="True"
                                 Text="(no folder selected)"/>
                        <Button Grid.Column="1"
                                Content="Browse..."
                                Style="{StaticResource ActionButtonStyle}"
                                MinWidth="90"
                                Click="RepairBrowse_Click"/>
                    </Grid>

                    <!-- Options + Run -->
                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <CheckBox x:Name="RepairSubfoldersCheckBox"
                                      Content="Include subfolders"
                                      Foreground="#CCCCCC"
                                      IsChecked="True"
                                      VerticalAlignment="Center"
                                      Margin="0,0,20,0"/>
                            <CheckBox x:Name="RepairDryRunCheckBox"
                                      Content="Dry run (preview only, no changes)"
                                      Foreground="#FFCC66"
                                      IsChecked="True"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="RepairRunButton"
                                Grid.Column="1"
                                Content="Scan and Repair"
                                Background="#005588"
                                Foreground="White"
                                BorderBrush="#0077AA"
                                BorderThickness="1"
                                Padding="12,6"
                                Cursor="Hand"
                                IsEnabled="False"
                                Click="RepairRun_Click"/>
                    </Grid>

                    <!-- Log output -->
                    <Border Grid.Row="3"
                            Background="#0D0D12"
                            BorderBrush="#333344"
                            BorderThickness="1">
                        <ScrollViewer x:Name="RepairLogScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="RepairLogTextBox"
                                     Background="Transparent"
                                     Foreground="#CCCCCC"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     Padding="8"
                                     Text="Select a folder and click Scan and Repair..."/>
                        </ScrollViewer>
                    </Border>

                    <!-- Summary bar -->
                    <Border Grid.Row="4"
                            Background="#252530"
                            BorderBrush="#444455"
                            BorderThickness="1"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="RepairSummaryTextBlock"
                                       Grid.Column="0"
                                       Foreground="#888899"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Text="Ready."/>
                            <Button Grid.Column="1"
                                    Content="Copy Log"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="RepairCopyLog_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Dialog Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource ActionButtonStyle}"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save Pattern"
                    Background="#0055AA"
                    Foreground="White"
                    BorderBrush="#0077CC"
                    BorderThickness="1"
                    Padding="10,6"
                    Width="120"
                    Cursor="Hand"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>