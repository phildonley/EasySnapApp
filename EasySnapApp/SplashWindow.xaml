<Window x:Class="EasySnapApp.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Width="800"
        Height="500"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- Background splash image -->
        <Image Source="{Binding SplashImage}"
           Stretch="Fill"
           SnapsToDevicePixels="True"/>

        <!-- Overlay areas (no visible boxes, pixel-perfect placement) -->
        <Canvas>

            <!-- Loading / status text area -->
            <!-- 270 x 45 at X=27, Y=170 -->
            <TextBlock Canvas.Left="27"
                   Canvas.Top="170"
                   Width="270"
                   Height="45"
                   Text="{Binding StatusText}"
                   FontFamily="Segoe UI"
                   FontSize="14"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Foreground="#0C5A98"
                   VerticalAlignment="Center" />

            <!-- Footer / copyright / version area -->
            <!-- 270 x 200 at X=27, Y=280 -->
            <TextBlock Canvas.Left="27"
                   Canvas.Top="280"
                   Width="270"
                   Height="200"
                   Text="{Binding FooterText}"
                   FontFamily="Segoe UI"
                   FontSize="18"
                   FontWeight="Normal"
                   TextWrapping="Wrap"
                   Foreground="#0C5A98" />

        </Canvas>
    </Grid>
</Window>
